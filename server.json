{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.nimblebrain/YOUR_SERVER_NAME",
  "title": "YOUR_DISPLAY_NAME",
  "description": "TODO: one-line description of what this MCP server does",
  "version": "0.1.0",
