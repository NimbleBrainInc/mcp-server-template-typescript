      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "YOUR_API_KEY_ENV_VAR",
          "description": "TODO: describe where the user can get this key",
          "isRequired": true,
          "isSecret": true
        }
      ]
